+// DBus System Event Listener (F36) implementation
+int on_prepare_for_sleep(sd_bus_message *m, void *userdata, sd_bus_error *ret_error) {
+    int active;
+    int r = sd_bus_message_read(m, "b", &active);
+    if (r >= 0) {
+        if (active) {
+            std::cout << "[DBus Listener] System preparing to sleep. Pausing tracking." << std::endl;
+            g_tracking_paused = true;
+        } else {
+            std::cout << "[DBus Listener] System resumed from sleep. Resuming tracking." << std::endl;
+            g_tracking_paused = false;
+        }
+    }
+    return 0;
+}
+
+int on_session_lock(sd_bus_message *m, void *userdata, sd_bus_error *ret_error) {
+    std::cout << "[DBus Listener] Session locked. Pausing tracking." << std::endl;
+    g_tracking_paused = true;
+    return 0;
+}
+
+int on_session_unlock(sd_bus_message *m, void *userdata, sd_bus_error *ret_error) {
+    std::cout << "[DBus Listener] Session unlocked. Resuming tracking." << std::endl;
+    g_tracking_paused = false;
+    return 0;
+}
+
+void dbusSystemEventListenerThread() {
+    sd_bus *bus = nullptr;
+    int r = sd_bus_open_system(&bus);
+    if (r < 0) {
+        std::cerr << "[DBus Listener] Failed to connect to system bus: " << strerror(-r) << std::endl;
+        return;
+    }
+    
+    sd_bus_slot *slot_sleep = nullptr;
+    sd_bus_slot *slot_lock = nullptr;
+    sd_bus_slot *slot_unlock = nullptr;
+    
+    r = sd_bus_add_match(bus, &slot_sleep,
+                         "type='signal',sender='org.freedesktop.login1',interface='org.freedesktop.login1.Manager',member='PrepareForSleep'",
+                         on_prepare_for_sleep, nullptr);
+    r = sd_bus_add_match(bus, &slot_lock,
+                         "type='signal',sender='org.freedesktop.login1',interface='org.freedesktop.login1.Session',member='Lock'",
+                         on_session_lock, nullptr);
+    r = sd_bus_add_match(bus, &slot_unlock,
+                         "type='signal',sender='org.freedesktop.login1',interface='org.freedesktop.login1.Session',member='Unlock'",
+                         on_session_unlock, nullptr);
+    
+    std::cout << "[DBus Listener] System Event Listener thread started." << std::endl;
+    
+    while (true) {
+        r = sd_bus_process(bus, nullptr);
+        if (r < 0) break;
+        if (r > 0) continue;
+        r = sd_bus_wait(bus, 1000000); // Wait up to 1 second
+        if (r < 0) break;
+    }
+    
+    sd_bus_slot_unref(slot_sleep);
+    sd_bus_slot_unref(slot_lock);
+    sd_bus_slot_unref(slot_unlock);
+    sd_bus_close_unref(bus);
+}
+
+// DBus Session Controller (F42 IPC) implementation
+static int method_pause(sd_bus_message *m, void *userdata, sd_bus_error *ret_error) {
+    g_tracking_paused = true;
+    std::cout << "[DBus Controller] Tracking paused." << std::endl;
+    return sd_bus_reply_method_return(m, "s", "Tracking paused");
+}
+
+static int method_resume(sd_bus_message *m, void *userdata, sd_bus_error *ret_error) {
+    g_tracking_paused = false;
+    std::cout << "[DBus Controller] Tracking resumed." << std::endl;
+    return sd_bus_reply_method_return(m, "s", "Tracking resumed");
+}
+
+static int method_configure(sd_bus_message *m, void *userdata, sd_bus_error *ret_error) {
+    double eps, sens, budget;
+    int r = sd_bus_message_read(m, "ddd", &eps, &sens, &budget);
+    if (r < 0) {
+        return sd_bus_reply_method_errorf(m, SD_BUS_ERROR_INVALID_ARGS, "Expected three doubles");
+    }
+    {
+        std::lock_guard<std::mutex> lock(g_config_mutex);
+        g_config.epsilon = eps;
+        g_config.sensitivity = sens;
+        g_config.budget = budget;
+    }
+    std::cout << "[DBus Controller] Reconfigured via D-Bus: epsilon=" << eps << ", budget=" << budget << std::endl;
+    return sd_bus_reply_method_return(m, "s", "Reconfigured successfully");
+}
+
+static int method_get_status(sd_bus_message *m, void *userdata, sd_bus_error *ret_error) {
+    double eps, sens, budget;
+    {
+        std::lock_guard<std::mutex> lock(g_config_mutex);
+        eps = g_config.epsilon;
+        sens = g_config.sensitivity;
+        budget = g_config.budget;
+    }
+    double cumulative = getCumulativeEpsilon24h("telemetry_buffer.db");
+    return sd_bus_reply_method_return(m, "bdddd", (int)g_tracking_paused.load(), eps, sens, budget, cumulative);
+}
+
+static const sd_bus_vtable control_vtable[] = {
+    SD_BUS_VTABLE_START(0),
+    SD_BUS_METHOD("Pause", "", "s", method_pause, SD_BUS_VTABLE_UNPRIVILEGED),
+    SD_BUS_METHOD("Resume", "", "s", method_resume, SD_BUS_VTABLE_UNPRIVILEGED),
+    SD_BUS_METHOD("Configure", "ddd", "s", method_configure, SD_BUS_VTABLE_UNPRIVILEGED),
+    SD_BUS_METHOD("GetStatus", "", "bdddd", method_get_status, SD_BUS_VTABLE_UNPRIVILEGED),
+    SD_BUS_VTABLE_END
+};
+
+void dbusSessionControllerThread() {
+    sd_bus *bus = nullptr;
+    int r = sd_bus_open_user(&bus);
+    if (r < 0) {
+        std::cerr << "[DBus Controller] Failed to connect to user bus: " << strerror(-r) << std::endl;
+        return;
+    }
+    
+    r = sd_bus_add_object_vtable(bus, nullptr, "/org/chronos/EdgeDaemon", "org.chronos.EdgeDaemon.Controller", control_vtable, nullptr);
+    if (r < 0) {
+        std::cerr << "[DBus Controller] Failed to register vtable: " << strerror(-r) << std::endl;
+        sd_bus_close_unref(bus);
+        return;
+    }
+    
+    r = sd_bus_request_name(bus, "org.chronos.EdgeDaemon", 0);
+    if (r < 0) {
+        std::cerr << "[DBus Controller] Failed to request name: " << strerror(-r) << std::endl;
+        sd_bus_close_unref(bus);
+        return;
+    }
+    
+    std::cout << "[DBus Controller] Session Controller registered on org.chronos.EdgeDaemon." << std::endl;
+    
+    while (true) {
+        r = sd_bus_process(bus, nullptr);
+        if (r < 0) break;
+        if (r > 0) continue;
+        r = sd_bus_wait(bus, 1000000);
+        if (r < 0) break;
+    }
+    
+    sd_bus_close_unref(bus);
+}
